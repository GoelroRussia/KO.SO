<Window
    x:Class="SteelBar.Views.CopyState.CopyStateView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:viewModel="clr-namespace:SteelBar.ViewModels.CopyState"
    mc:Ignorable="d"
    Title="Copy Setting Template" Height="250" Width="400"
    WindowStartupLocation="CenterScreen" ResizeMode="NoResize">



    <Grid Margin="0,0,0,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Chọn thuộc tính để sao chép vào bộ nhớ tạm:"/>

        <WrapPanel Grid.Row="1" Margin="10,10,0,10" Orientation="Horizontal" ItemWidth="300" ItemHeight="25">
            <CheckBox Content="Visibility Graphics" IsChecked="{Binding IsVisibilityGraphicsSelected}"/>
            <CheckBox Content="3D Section Box State" IsChecked="{Binding IsSectionBoxSelected}" IsEnabled="{Binding Is3DView}"/>
            <CheckBox Content="Crop Region" IsChecked="{Binding IsCropRegionSelected}"/>
            <CheckBox Content="Filter Overrides" IsChecked="{Binding IsFiltersSelected}"/>
        </WrapPanel>

        <Button Grid.Row="2" Content="Copy State" Command="{Binding CopyCommand}" 
                Width="100" Height="30" HorizontalAlignment="Right" Margin="0,10,10,0"
                Background="#2196F3" Foreground="White"/>
    </Grid>
</Window>