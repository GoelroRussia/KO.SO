<Window x:Class="SteelBar.Views.RebarCheckerView"
		xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:viewModels="clr-namespace:SteelBar.ViewModels"
		xmlns:control="http://filterdatagrid.control.com/2021"
		Title="Rebar Precision Checker Pro" Height="800" Width="1300"
		WindowStartupLocation="CenterScreen" Background="#F5F5F5">


    
    <Grid Margin="15" Height="700">

        <Grid.RowDefinitions>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="*"/>

            <RowDefinition Height="Auto"/>

        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>

            <ColumnDefinition Width="220"/>

            <ColumnDefinition Width="*"/>

        </Grid.ColumnDefinitions>


        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,15">

            <TextBlock Text="Làm tròn (mm):" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold"/>

            <TextBox Text="{Binding RoundingStep}" Width="70" Height="30" VerticalContentAlignment="Center"/>


            <Button Content="CHECK" 
					Width="70" Height="30"
					Command="{Binding CheckRebarsCommand}" 
					Padding="15,5" Margin="10,0" Background="#2196F3" Foreground="White" FontWeight="Bold" Cursor="Hand"/>

            <Button Content="AUTO ROUNDING" 
					Command="{Binding AutoRoundRebarsCommand}" 
					CommandParameter="{Binding Items, ElementName=RebarDataGrid}" 
					Width="120" Height="30" Padding="5" Margin="0,0,10,0" Cursor="Hand" 
					Background="#FF9800" Foreground="White" FontWeight="Bold" BorderThickness="0"
					ToolTip="Đề xuất số làm tròn cho các thanh thép ĐANG HIỂN THỊ trên bảng"/>

            <Button Content="UPDATE" Command="{Binding ApplyChangesCommand}" 
					Width="70" Height="30" Padding="5" Cursor="Hand" 
					Background="#2196F3" Foreground="White" FontWeight="Bold" BorderThickness="0"/>

            <Button Content="ZOOM IN" 
					Command="{Binding ZoomInCommand}"
					Width="70" Height="30" Margin="10,0,10,0" 
					Background="#2196F3" Foreground="White"/>

            <Button Content="SELECT" 
					Command="{Binding SelectElementsCommand}" 
					Width="70" Height="30" Margin="0,0,10,0" 
					Background="#2196F3" Foreground="White"/>

            <Button Content="COVER CHECK" 
					Command="{Binding CheckConcreteCoverCommand}"
					Width="90" Height="30"
					Margin="5" Background="#2196F3" Foreground="White"/>

        </StackPanel>


        <GroupBox Grid.Row="1" Grid.Column="0" Header="Lọc theo cấu kiện chứa thép" Margin="0,0,10,0" Padding="5">

            <ScrollViewer VerticalScrollBarVisibility="Auto">

                <ItemsControl ItemsSource="{Binding HostCategories}">

                    <ItemsControl.ItemTemplate>

                        <DataTemplate>

                            <CheckBox Content="{Binding CategoryName}" IsChecked="{Binding IsSelected}" Margin="0,5" Cursor="Hand"/>

                        </DataTemplate>

                    </ItemsControl.ItemTemplate>

                </ItemsControl>

            </ScrollViewer>

        </GroupBox>


        <DataGrid Grid.Column="1" Grid.Row="1" 
                x:Name="RebarDataGrid"
                ItemsSource="{Binding RebarList}" 
                SelectionMode="Extended"
                AutoGenerateColumns="False" 
                HeadersVisibility="Column"
                SelectionChanged="MyDataGrid_SelectionChanged"
                GridLinesVisibility="All">

            <DataGrid.Columns>

                <DataGridTextColumn Header="Assembly Name" Binding="{Binding AssemblyName}" Width="160" IsReadOnly="True"/>
                <DataGridTextColumn Header="REBAR TYPE" Binding="{Binding REBAR_TYPE}" Width="150" IsReadOnly="True"/>

                <DataGridTextColumn Header="Element ID" Binding="{Binding ElementId}" Width="100" />

                <DataGridTemplateColumn Header="Shape" Width="220">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Image Source="{Binding ShapeImage}" 
                           Stretch="Uniform" 
                           Width="500" Height="220"
                           Margin="5" 
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Parameter Name" Binding="{Binding ParameterName}" Width="120" IsReadOnly="True"/>

                <DataGridTextColumn Header="Value (mm)" 
                            Binding="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" 
                            Width="120" 
                            IsReadOnly="False"/>

                <DataGridTextColumn Header="Cover Status" 
                            Binding="{Binding CoverStatus}" 
                            Width="100" 
                            IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCoverFailed}" Value="True">
                                    <Setter Property="Foreground" Value="Red"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsCoverFailed}" Value="False">
                                    <Setter Property="Foreground" Value="Green"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="2" Grid.Column="1" Margin="0,10,0,0">

            <StackPanel>

                <TextBlock Text="{Binding ProgressText}" FontSize="11" Margin="0,0,0,2"/>

                <ProgressBar Value="{Binding ProgressValue}" Height="12" Minimum="0" Maximum="100" Foreground="#4CAF50" />

            </StackPanel>


            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" >

                <TextBlock Text="Tổng thép lỗi: " Foreground="#444"/>

                <TextBlock Text="{Binding TotalRebars}" FontWeight="Bold" Foreground="Red" Margin="0,0,20,0"/>

                <TextBlock Text="Số Assembly lỗi: " Foreground="#444"/>

                <TextBlock Text="{Binding TotalAssemblies}" FontWeight="Bold" Foreground="#2196F3"/>

            </StackPanel>

        </Grid>

    </Grid>

</Window>