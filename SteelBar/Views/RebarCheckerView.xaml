<Window x:Class="SteelBar.Views.RebarCheckerView"
		xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:viewModels="clr-namespace:SteelBar.ViewModels"
		xmlns:control="http://filterdatagrid.control.com/2021"
		Title="Kiểm tra thép" Height="800" Width="1200"
		WindowStartupLocation="CenterScreen" Background="#F5F5F5">
    <Window.Resources>
        <Style x:Key="CenterText" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="SelectionUnit" Value="Cell"/>
            <Setter Property="GridLinesVisibility" Value="All"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#DDDDDD"/>
            <Setter Property="VerticalGridLinesBrush" Value="#DDDDDD"/>
            <Setter Property="RowHeight" Value="180"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="AlternationCount" Value="2"/>
            <Setter Property="AlternatingRowBackground" Value="#EBEBEB"/>
        </Style>
        <Style x:Key="ExcelFilterHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="ContentTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="4">
                            <TextBlock Text="{Binding}" VerticalAlignment="Center" Margin="0,0,10,0"/>

                            <ToggleButton x:Name="FilterBtn" Content="▼" Width="20" Height="20" 
                                      Background="Transparent" BorderBrush="Transparent" Cursor="Hand"
                                      Tag="{Binding Column.SortMemberPath, RelativeSource={RelativeSource AncestorType=DataGridColumnHeader}}"
                                      Checked="FilterBtn_Checked"/>

                            <Popup IsOpen="{Binding IsChecked, ElementName=FilterBtn}" 
                               StaysOpen="False" PlacementTarget="{Binding ElementName=FilterBtn}"
                               Closed="FilterPopup_Closed">

                                <Border Background="White" BorderBrush="Gray" BorderThickness="1" Padding="5" MaxHeight="300" MinWidth="180">
                                    <DockPanel>

                                        <CheckBox x:Name="SelectAllCb" Content="(Chọn tất cả)" 
                                              DockPanel.Dock="Top" Margin="5,5,5,10" FontWeight="Bold"
                                              IsChecked="True" Click="SelectAll_Click"
                                              Tag="{Binding Column.SortMemberPath, RelativeSource={RelativeSource AncestorType=DataGridColumnHeader}}"/>

                                        <Border DockPanel.Dock="Top" Height="1" Background="#DDDDDD" Margin="0,0,0,5"/>

                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <ItemsControl x:Name="FilterItemsControl">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <CheckBox Content="{Binding Value}" 
                                                              IsChecked="{Binding IsSelected}" 
                                                              Margin="5,4" Cursor="Hand"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>

                                    </DockPanel>
                                </Border>
                            </Popup>
                        </StackPanel>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ExportButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="80"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Margin" Value="10,0,0,0"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="4"/>
                </Style>
            </Style.Resources>
        </Style>
    </Window.Resources>


    <Grid Margin="15" Height="700">

        <Grid.RowDefinitions>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="*"/>

            <RowDefinition Height="Auto"/>

        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>

            <ColumnDefinition Width="220"/>

            <ColumnDefinition Width="*"/>

        </Grid.ColumnDefinitions>


        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,15">

            <TextBlock Text="Làm tròn (mm):" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold"/>

            <TextBox Text="{Binding RoundingStep}" Width="70" Height="30" VerticalContentAlignment="Center"/>


            <Button Content="Check"
					Command="{Binding CheckRebarsCommand}"
                    Style="{StaticResource ExportButtonStyle}">
            </Button>
            <Button Content="Auto Rounding" Width="100"
					Command="{Binding AutoRoundRebarsCommand}" 
					CommandParameter="{Binding Items, ElementName=RebarDataGrid}" 
                    Style="{StaticResource ExportButtonStyle}">
            </Button>
            <Button Content="Update" 
                    Command="{Binding ApplyChangesCommand}" 
					Style="{StaticResource ExportButtonStyle}">
            </Button>
            <Button Content="Zoom In" 
					Command="{Binding ZoomInCommand}"
					Style="{StaticResource ExportButtonStyle}">
            </Button>

            <Button Content="Select" 
					Command="{Binding SelectElementsCommand}" 
					Style="{StaticResource ExportButtonStyle}"/>
            <Button Content="Cover Check" 
					Command="{Binding CheckConcreteCoverCommand}"
					Style="{StaticResource ExportButtonStyle}"/>

        </StackPanel>


        <GroupBox Grid.Row="1" Grid.Column="0" Header="Chọn cấu kiện host thép" Margin="0,0,10,0" FontSize="13" Padding="5">

            <ScrollViewer VerticalScrollBarVisibility="Auto">

                <ItemsControl ItemsSource="{Binding HostCategories}">

                    <ItemsControl.ItemTemplate>

                        <DataTemplate>

                            <CheckBox Content="{Binding CategoryName}" IsChecked="{Binding IsSelected}" Margin="0,5" Cursor="Hand"/>

                        </DataTemplate>

                    </ItemsControl.ItemTemplate>

                </ItemsControl>

            </ScrollViewer>

        </GroupBox>


        <DataGrid Grid.Column="1" Grid.Row="1" 
                x:Name="RebarDataGrid"
                ItemsSource="{Binding RebarList}" 
                SelectionMode="Extended"
                AutoGenerateColumns="False" 
                HeadersVisibility="All"
                SelectionChanged="MyDataGrid_SelectionChanged"
                GridLinesVisibility="All">
            <DataGrid.Columns>

                <DataGridTextColumn Header="Assembly Name" Binding="{Binding AssemblyName}" Width="130" IsReadOnly="True"
                                    HeaderStyle="{StaticResource ExcelFilterHeaderStyle}"
                                    SortMemberPath="AssemblyName"/>
                <DataGridTextColumn Header="Rebar Type" Binding="{Binding REBAR_TYPE}" Width="120" IsReadOnly="True"
                                    HeaderStyle="{StaticResource ExcelFilterHeaderStyle}"
                                    SortMemberPath="REBAR_TYPE"/>

                <DataGridTextColumn Header="Element ID" Binding="{Binding ElementId}" Width="100" IsReadOnly="True"
                                    HeaderStyle="{StaticResource ExcelFilterHeaderStyle}"
                                    SortMemberPath="ElementId"/>

                <DataGridTemplateColumn Header="Shape" Width="220"
                                        HeaderStyle="{StaticResource ExcelFilterHeaderStyle}"
                                        SortMemberPath="ShapeName">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Image Source="{Binding ShapeImage}" 
                           Stretch="Uniform" 
                           Width="500" Height="220"
                           Margin="5" 
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Parameter Name" Binding="{Binding ParameterName}" Width="135" IsReadOnly="True"
                                    HeaderStyle="{StaticResource ExcelFilterHeaderStyle}"
                                    SortMemberPath="ParameterName"/>

                <DataGridTextColumn Header="Value (mm)" 
                            Binding="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" 
                            Width="110" 
                            IsReadOnly="False"
                            HeaderStyle="{StaticResource ExcelFilterHeaderStyle}"
                            SortMemberPath="Value"/>

                <DataGridTextColumn Header="Cover Status" 
                            Binding="{Binding CoverStatus}" 
                            Width="120" 
                            IsReadOnly="True"
                            HeaderStyle="{StaticResource ExcelFilterHeaderStyle}"
                            SortMemberPath="CoverStatus">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCoverFailed}" Value="True">
                                    <Setter Property="Foreground" Value="Red"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsCoverFailed}" Value="False">
                                    <Setter Property="Foreground" Value="Green"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="2" Grid.Column="1" Margin="0,10,0,0">

            <StackPanel>

                <TextBlock Text="{Binding ProgressText}" FontSize="11" Margin="0,0,0,2"/>

                <ProgressBar Value="{Binding ProgressValue}" Height="12" Minimum="0" Maximum="100" Foreground="#4CAF50" />

            </StackPanel>


            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" >

                <TextBlock Text="Tổng thép lỗi: "/>

                <TextBlock Text="{Binding TotalRebars}" FontWeight="Bold" Foreground="Red" Margin="0,0,20,0"/>

                <TextBlock Text="Số Assembly lỗi: " />

                <TextBlock Text="{Binding TotalAssemblies}" FontWeight="Bold" Foreground="#2196F3"/>

            </StackPanel>

        </Grid>

    </Grid>

</Window>