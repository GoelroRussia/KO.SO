<Window x:Class="SteelBar.Views.RebarCheckerView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:SteelBar.ViewModels"
        d:DataContext="{d:DesignInstance viewModels:RebarCheckerViewModel}"
        mc:Ignorable="d"
        Title="Kiểm tra Thép Lẻ Số" Height="450" Width="850"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" 
                    Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Làm tròn tới (mm): " VerticalAlignment="Center" FontWeight="SemiBold"/>
            <TextBox Width="70" Margin="5,0,20,0" VerticalContentAlignment="Center"
                     Text="{Binding RoundingStep, UpdateSourceTrigger=PropertyChanged}"/>
            <Button Content="Kiểm tra" Command="{Binding CheckRebarsCommand}" 
                    Width="100" Padding="5" Cursor="Hand"/>
        </StackPanel>

        <GroupBox Grid.Row="1" Grid.Column="0" Header="Chọn Host Category" Margin="0,0,10,0" Padding="5">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding HostCategories}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <CheckBox Content="{Binding CategoryName}" 
                                      IsChecked="{Binding IsSelected}" 
                                      Margin="0,5,0,5"
                                      Cursor="Hand"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </GroupBox>

        <DataGrid Grid.Row="1" Grid.Column="1" ItemsSource="{Binding RebarList}" 
                  SelectedItem="{Binding SelectedRebar}"
                  AutoGenerateColumns="False" 
                  IsReadOnly="True" 
                  HeadersVisibility="Column"
                  GridLinesVisibility="All">

            <DataGrid.InputBindings>
                <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding ZoomToRebarCommand}"/>
            </DataGrid.InputBindings>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Element ID" Binding="{Binding ElementId}" Width="100"/>
                <DataGridTextColumn Header="Assembly Name" Binding="{Binding AssemblyName}" Width="150"/>
                <DataGridTextColumn Header="Parameter Name" Binding="{Binding ParameterName}" Width="*"/>
                <DataGridTextColumn Header="Value (mm)" Binding="{Binding Value}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <TextBlock Text="Tổng số Element: " FontWeight="SemiBold" Foreground="#444444"/>
            <TextBlock Text="{Binding TotalRebars}" FontWeight="Bold" Margin="0,0,20,0" Foreground="#d9534f"/>
            <TextBlock Text="Tổng số Assembly: " FontWeight="SemiBold" Foreground="#444444"/>
            <TextBlock Text="{Binding TotalAssemblies}" FontWeight="Bold" Foreground="#d9534f"/>
        </StackPanel>
        </Grid>
</Window>