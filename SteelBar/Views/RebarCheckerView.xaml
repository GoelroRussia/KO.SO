<Window x:Class="SteelBar.Views.RebarCheckerView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewModels="clr-namespace:SteelBar.ViewModels"
        xmlns:control="http://filterdatagrid.control.com/2021"
        Title="Rebar Precision Checker Pro" Height="800" Width="900"
        WindowStartupLocation="CenterScreen" Background="#F5F5F5">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/FilterDataGrid;component/Themes/Generic.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            <viewModels:Converter x:Key="InverseBooleanConverter" />
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="15" Height="700">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="Làm tròn (mm):" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold"/>
            <TextBox Text="{Binding RoundingStep}" Width="70" VerticalContentAlignment="Center"/>

            <Button Content="CHECK" 
                    Command="{Binding CheckRebarsCommand}" 
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}"
                    Padding="15,5" Margin="20,0" Background="#2196F3" Foreground="White" FontWeight="Bold" Cursor="Hand"/>
            <Button Content="AUTO ROUNDING" 
                    Command="{Binding AutoRoundRebarsCommand}" 
                    CommandParameter="{Binding Items, ElementName=RebarDataGrid}" 
                    Width="150" Padding="5" Margin="0,0,10,0" Cursor="Hand" 
                    Background="#FF9800" Foreground="White" FontWeight="Bold" BorderThickness="0"
                    ToolTip="Đề xuất số làm tròn cho các thanh thép ĐANG HIỂN THỊ trên bảng"/>
            <Button Content="UPDATE" Command="{Binding ApplyChangesCommand}" 
                    Width="70" Padding="5" Cursor="Hand" 
                    Background="#2196F3" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
            <Button Content="ZOOM IN" 
                    Command="{Binding ZoomInCommand}" 
                    Width="70" Height="30" Margin="10,0,10,0" 
                    Background="#2196F3" Foreground="White"/>
            <Button Content="SELECT" 
                    Command="{Binding SelectElementsCommand}" 
                    CommandParameter="{Binding ElementName=RebarDataGrid, Path=SelectedItems}"
                    Width="70" Height="30" Margin="0,0,10,0" 
                    Background="#2196F3" Foreground="White"/>
        </StackPanel>

        <GroupBox Grid.Row="1" Grid.Column="0" Header="Lọc theo cấu kiện chứa thép" Margin="0,0,10,0" Padding="5">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding HostCategories}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <CheckBox Content="{Binding CategoryName}" IsChecked="{Binding IsSelected}" Margin="0,5" Cursor="Hand"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </GroupBox>

        <control:FilterDataGrid Grid.Column="1" Grid.Row="1" 
                                x:Name="RebarDataGrid"
                                ItemsSource="{Binding RebarList}" 
                                SelectedItem="{Binding SelectedRebar, Mode=TwoWay}"
                                SelectionMode="Extended"
                                AutoGenerateColumns="False" 
                                HeadersVisibility="Column"
                                GridLinesVisibility="All"
                                ShowStatusBar="True" 
                                FilterLanguage="English"
                                ExcludeFields="ShapeGeometry" SelectionChanged="RebarDataGrid_SelectionChanged">
            <control:FilterDataGrid.Columns>
                <control:DataGridTextColumn Header="Assembly Name" Binding="{Binding AssemblyName}" Width="150" IsColumnFiltered="True" IsReadOnly="True"/>
                <control:DataGridTextColumn Header="Element ID" Binding="{Binding ElementId}" Width="100" IsColumnFiltered="True"/>
                <control:DataGridTemplateColumn Header="Shape" Width="90" IsColumnFiltered="False" FieldName="ShapeGeometry">
                    <control:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Path Data="{Binding ShapeGeometry}" Stretch="Uniform" Width="60" Height="40" Margin="5" Stroke="Red" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </control:DataGridTemplateColumn.CellTemplate>
                </control:DataGridTemplateColumn>                
                <control:DataGridTextColumn Header="Parameter Name" Binding="{Binding ParameterName}" Width="120" IsColumnFiltered="True" IsReadOnly="True"/>
                <control:DataGridTextColumn Header="Value (mm)" 
                                            Binding="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" 
                                            Width="*" 
                                            IsColumnFiltered="True" 
                                            IsReadOnly="False"/>
            </control:FilterDataGrid.Columns>
        </control:FilterDataGrid>
        <Grid Grid.Row="2" Grid.Column="1" Margin="0,10,0,0">
            <StackPanel Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="{Binding ProgressText}" FontSize="11" Margin="0,0,0,2"/>
                <ProgressBar Value="{Binding ProgressValue}" Height="12" Minimum="0" Maximum="100" Foreground="#4CAF50" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" 
                        Visibility="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}">
                <TextBlock Text="Tổng thép lỗi: " Foreground="#444"/>
                <TextBlock Text="{Binding TotalRebars}" FontWeight="Bold" Foreground="Red" Margin="0,0,20,0"/>
                <TextBlock Text="Số Assembly lỗi: " Foreground="#444"/>
                <TextBlock Text="{Binding TotalAssemblies}" FontWeight="Bold" Foreground="#2196F3"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>